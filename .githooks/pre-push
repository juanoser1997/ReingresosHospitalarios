#!/bin/bash
# .githooks/pre-push
# Ejecuta los tests unitarios antes de cada push.
# Para saltarse el hook en casos de emergencia: git push --no-verify

set -e

echo "Ejecutando tests unitarios antes del push..."

if command -v uv &> /dev/null; then
    uv run pytest tests/unit/ -q --no-header
else
    python -m pytest tests/unit/ -q --no-header
fi

echo "Tests pasaron. Procediendo con el push."
